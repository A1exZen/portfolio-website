# Copy to .env.local for `vercel dev`, and set the same values in the
# Vercel dashboard (Project → Settings → Environment Variables) for prod.

# BotFather (https://t.me/BotFather) → /newbot → gives you this token.
TELEGRAM_BOT_TOKEN=

# The chat that should receive enquiries — usually your own numeric user id.
# Easiest way to get it: message @userinfobot on Telegram, it replies with
# your id. Group chats work too (start with a "-").
TELEGRAM_CHAT_ID=
